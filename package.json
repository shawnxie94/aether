{
  "name": "aether-codex-plugin",
  "version": "0.0.3",
  "description": "Aether Codex plugin marketplace package for visual asset memory, prompt refinement, and image generation workflows.",
  "license": "MIT",
  "author": "Aether",
  "type": "commonjs",
  "bin": {
    "aether-codex-plugin": "scripts/aether-plugin.js",
    "aether-plugin": "scripts/aether-plugin.js"
  },
  "files": [
    ".agents/",
    "plugins/aether/.codex-plugin/",
    "plugins/aether/config.json",
    "plugins/aether/examples/",
    "plugins/aether/pyproject.toml",
    "plugins/aether/schemas/",
    "plugins/aether/scripts/",
    "plugins/aether/skills/",
    "plugins/aether/src/",
    "scripts/aether-plugin.js",
    "README.md",
    "AGENT.md"
  ],
  "scripts": {
    "pack:plugin": "npm pack --pack-destination dist",
    "validate:plugin": "node scripts/aether-plugin.js doctor",
    "test": "PYTHONPATH=src python -m unittest discover -s plugins/aether/tests"
  },
  "keywords": [
    "codex",
    "codex-plugin",
    "image-generation",
    "prompt-refinement",
    "visual-asset-memory"
  ],
  "engines": {
    "node": ">=18"
  }
}
