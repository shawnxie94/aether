{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Aether Visual Asset",
  "type": "object",
  "required": ["type", "name"],
  "properties": {
    "id": {"type": "string"},
    "type": {
      "type": "string",
      "enum": [
        "style",
        "color_palette",
        "lighting",
        "composition",
        "camera",
        "mood",
        "scene",
        "texture",
        "character",
        "prop_symbol",
        "shape_line",
        "negative_rule"
      ]
    },
    "name": {"type": "string"},
    "summary": {"type": "string"},
    "tags": {"type": "array"},
    "profile": {"type": "object"},
    "source_references": {"type": "array"},
    "prompt_fragments": {"type": "array", "items": {"type": "string"}},
    "negative_fragments": {"type": "array", "items": {"type": "string"}},
    "compatible_with": {"type": "array"},
    "avoid_with": {"type": "array"},
    "recommended_aspect_ratios": {"type": "array", "items": {"type": "string"}},
    "status": {"type": "string"},
    "parent_asset_id": {"type": ["string", "null"]},
    "merged_into_asset_id": {"type": ["string", "null"]}
  }
}
