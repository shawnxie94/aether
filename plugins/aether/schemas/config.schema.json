{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Aether Config",
  "type": "object",
  "required": ["schemaVersion", "project", "storage", "style", "prompt", "generation", "codex", "backend"],
  "properties": {
    "schemaVersion": {"type": "integer"},
    "project": {
      "type": "object",
      "required": ["name", "productForm"],
      "properties": {
        "name": {"type": "string"},
        "description": {"type": "string"},
        "productForm": {"type": "string"}
      }
    },
    "storage": {
      "type": "object",
      "required": ["databasePath", "assetRoot", "referenceImageDir", "generatedImageDir", "runDir", "cacheDir"],
      "properties": {
        "databasePath": {"type": "string"},
        "assetRoot": {"type": "string"},
        "referenceImageDir": {"type": "string"},
        "generatedImageDir": {"type": "string"},
        "runDir": {"type": "string"},
        "cacheDir": {"type": "string"}
      }
    },
    "style": {"type": "object"},
    "embedding": {
      "type": "object",
      "properties": {
        "provider": {"type": "string", "enum": ["disabled", "openai", "siliconflow", "local"]},
        "model": {"type": "string"},
        "baseUrl": {"type": "string"},
        "apiKey": {"type": "string"},
        "dimensions": {"type": "integer", "minimum": 0},
        "batchSize": {"type": "integer", "minimum": 1},
        "cache": {
          "type": "object",
          "properties": {
            "mode": {"type": "string", "enum": ["sqlite"]},
            "rebuildOnModelChange": {"type": "boolean"}
          }
        },
        "providers": {
          "type": "object",
          "properties": {
            "openai": {
              "type": "object",
              "properties": {
                "baseUrl": {"type": "string"},
                "apiKey": {"type": "string"},
                "apiKeyEnv": {"type": "string"},
                "model": {"type": "string"},
                "dimensions": {"type": "integer", "minimum": 0}
              }
            },
            "siliconflow": {
              "type": "object",
              "properties": {
                "baseUrl": {"type": "string"},
                "apiKey": {"type": "string"},
                "apiKeyEnv": {"type": "string"},
                "model": {"type": "string"},
                "dimensions": {"type": "integer", "minimum": 0}
              }
            },
            "local": {
              "type": "object",
              "properties": {
                "command": {"type": "string"},
                "model": {"type": "string"},
                "dimensions": {"type": "integer", "minimum": 0}
              }
            }
          }
        }
      }
    },
    "prompt": {"type": "object"},
    "generation": {"type": "object"},
    "codex": {"type": "object"},
    "backend": {"type": "object"}
  }
}
