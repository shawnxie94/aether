{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Aether Prompt Record",
  "type": "object",
  "required": ["source_prompt", "refined_prompt"],
  "properties": {
    "id": {"type": "string"},
    "source_prompt": {"type": "string"},
    "target_generation_skill": {"type": ["string", "null"]},
    "selected_assets": {"type": "array"},
    "constraints": {"type": "object"},
    "intent_analysis": {"type": "object"},
    "intent_sketch": {"type": "object"},
    "recall_candidates": {
      "type": "object",
      "properties": {
        "visual_systems": {"type": "array"},
        "recipes": {"type": "array"},
        "visual_assets": {"type": "array"}
      }
    },
    "recall_strategy": {
      "type": "object",
      "properties": {
        "mode": {"type": "string"},
        "semantic_enabled": {"type": "boolean"},
        "embedding_provider": {"type": "string"},
        "embedding_model": {"type": "string"}
      }
    },
    "composition_plan": {"type": "object"},
    "refined_prompt": {"type": "string"},
    "negative_prompt": {"type": "string"},
    "generation_params": {"type": "object"},
    "variants": {"type": "array"},
    "assumptions": {"type": "array", "items": {"type": "string"}},
    "conflicts": {"type": "array"}
  }
}
