{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Aether Prompt Record",
  "type": "object",
  "required": ["source_prompt", "refined_prompt"],
  "properties": {
    "id": {"type": "string"},
    "source_prompt": {"type": "string"},
    "target_generation_skill": {"type": ["string", "null"]},
    "selected_assets": {"type": "array"},
    "constraints": {"type": "object"},
    "intent_analysis": {"type": "object"},
    "composition_plan": {"type": "object"},
    "refined_prompt": {"type": "string"},
    "negative_prompt": {"type": "string"},
    "generation_params": {"type": "object"},
    "variants": {"type": "array"},
    "assumptions": {"type": "array", "items": {"type": "string"}},
    "conflicts": {"type": "array"}
  }
}
