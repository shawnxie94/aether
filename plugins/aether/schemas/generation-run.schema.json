{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Aether Generation Run",
  "type": "object",
  "required": ["refined_prompt", "generation_skill"],
  "properties": {
    "id": {"type": "string"},
    "mode": {"type": "string", "enum": ["generate", "edit"]},
    "source_prompt": {"type": "string"},
    "refined_prompt": {"type": "string"},
    "negative_prompt": {"type": "string"},
    "source_generation_id": {"type": ["string", "null"]},
    "source_output_asset_id": {"type": ["string", "null"]},
    "edit_instruction": {"type": "string"},
    "edit_regions": {"type": "array"},
    "selected_assets": {"type": "array"},
    "generation_skill": {"type": "string"},
    "skill_params": {"type": "object"},
    "skill_result_meta": {"type": "object"},
    "visual_review": {"type": "object"},
    "outputs": {"type": "array"},
    "status": {"type": "string"},
    "feedback": {"type": "object"},
    "error": {"type": "string"}
  }
}
