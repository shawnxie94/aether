{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Aether Style Card",
  "type": "object",
  "required": ["name"],
  "properties": {
    "id": {"type": "string"},
    "name": {"type": "string"},
    "summary": {"type": "string"},
    "tags": {"type": "array", "items": {"type": "string"}},
    "source_references": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "image_path": {"type": "string"},
          "source_prompt": {"type": "string"},
          "user_note": {"type": "string"},
          "role": {"type": "string"},
          "asset_id": {"type": "string"},
          "sha256": {"type": "string"}
        }
      }
    },
    "style_profile": {"type": "object"},
    "prompt_template": {"type": "string"},
    "negative_prompt": {"type": "string"},
    "status": {"type": "string", "enum": ["draft", "active", "archived", "merged"]},
    "parent_style_id": {"type": ["string", "null"]},
    "merged_into_style_id": {"type": ["string", "null"]}
  }
}

